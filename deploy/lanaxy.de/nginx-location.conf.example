# In den HTTPS-server-Block für lanaxy.de einfügen.
# Der übrige Webauftritt kann unverändert bleiben.
location = /install.sh {
    alias /var/www/lanaxy/install.sh;
    default_type text/plain;
    charset utf-8;
    add_header Cache-Control "public, max-age=300" always;
    add_header X-Content-Type-Options "nosniff" always;
}
